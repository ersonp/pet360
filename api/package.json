{
  "name": "pet360-api",
  "version": "0.0.1",
  "description": "Pet360 blockchain bridge API — mints NFTs and manages IPFS metadata",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/testing": "11.1.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/supertest": "7.2.0",
    "jest": "29.7.0",
    "supertest": "7.2.2",
    "ts-jest": "29.4.9",
    "typescript": "5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "allowScripts": {
    "@nestjs/core@11.1.19": true
  }
}
