# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Port the API listens on
PORT=3000

# Pinata JWT — used to upload pet photos and metadata to IPFS
# Get from: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# PetPassport proxy contract address on the target network
# Copy from deployments/mumbai.json or deployments/polygon.json
CONTRACT_ADDRESS=

# Minter wallet private key (the wallet that has MINTER_ROLE on the contract)
# This is the NestJS API wallet — keep it separate from the deployer key
MINTER_PRIVATE_KEY=

# Polygon RPC URL — use Alchemy or Infura for reliability
# Mumbai: https://polygon-mumbai.g.alchemy.com/v2/<key>
# Mainnet: https://polygon-mainnet.g.alchemy.com/v2/<key>
POLYGON_RPC_URL=
