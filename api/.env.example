# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Port the API listens on
PORT=3000

# Pinata JWT — used to upload pet photos and metadata to IPFS (SDK v2 uses JWT, not API key)
# Get from: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# Pinata dedicated gateway domain (e.g. example-gateway.mypinata.cloud)
# Get from: https://app.pinata.cloud/gateway
PINATA_GATEWAY=

# PetPassport proxy contract address on the target network
# Copy from deployments/amoy.json or deployments/polygon.json
CONTRACT_ADDRESS=

# Minter wallet private key (the wallet that has MINTER_ROLE on the contract)
# This is the NestJS API wallet — keep it separate from the deployer key
MINTER_PRIVATE_KEY=

# Polygon RPC URL
# Amoy testnet (public): https://rpc-amoy.polygon.technology
# Mainnet (public): https://polygon-rpc.com
POLYGON_RPC_URL=
