# Copy to .env.local — NEVER commit .env.local to git

# URL of the NestJS API (task 06)
# Local: http://localhost:3000
# Production: https://api.pet360.com.br
NEXT_PUBLIC_API_URL=http://localhost:3000

# PetPassport proxy contract address (from deployments/amoy.json after deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# WalletConnect project ID — get from https://cloud.walletconnect.com
# Required for RainbowKit to work
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
