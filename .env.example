# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Deployer wallet private key (without 0x prefix)
# Get from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=

# Polygon Amoy testnet RPC URL
# Public RPC: https://rpc-amoy.polygon.technology (no account needed)
AMOY_RPC_URL=

# Polygonscan API key — used to verify contract source code publicly
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# NestJS API wallet address (the wallet that will have MINTER_ROLE)
# Can be the same as deployer for local dev, should be separate for production
MINTER_ADDRESS=

# Admin multisig address (the wallet that will have UPGRADER_ROLE)
# Can be the same as deployer for local dev, must be a multisig for production
UPGRADER_ADDRESS=
